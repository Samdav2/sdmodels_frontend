# SDModels API Configuration
# Development: http://localhost:8000/api/v1
# Production: https://your-backend-domain.com/api/v1 (replace with your actual backend URL)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Optional: WebSocket URL
NEXT_PUBLIC_WS_URL=ws://localhost:8000/api/v1/ws

# Optional: CDN URL for assets
NEXT_PUBLIC_CDN_URL=https://cdn.sdmodels.com

# Optional: Analytics
NEXT_PUBLIC_GA_ID=

# Paystack Configuration
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_62d6a1c731ffc99c8c9aa7f9eb44a90253afd9c8

# IMPORTANT FOR VERCEL DEPLOYMENT:
# 1. Set NEXT_PUBLIC_API_URL to your production backend URL in Vercel environment variables
# 2. Ensure your backend has CORS configured with these headers:
#    - Access-Control-Allow-Origin: https://your-vercel-domain.vercel.app
#    - Access-Control-Allow-Methods: GET, POST, PUT, DELETE, OPTIONS, PATCH
#    - Access-Control-Allow-Headers: Content-Type, Authorization
#    - Access-Control-Allow-Credentials: true
# 3. Backend must handle OPTIONS preflight requests and return 200 with CORS headers
